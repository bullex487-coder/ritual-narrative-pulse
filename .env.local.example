# ============================================================
# .env.local.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── OpenAI ───────────────────────────────────────────────────
# Required for production AI analysis (currently using mock data)
OPENAI_API_KEY=sk-...

# ── Hugging Face — free AI inference
# Create a token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# ── Ritual Network ───────────────────────────────────────────
# Ritual testnet RPC endpoint
RITUAL_RPC_URL=https://rpc.ritual.testnet
RITUAL_CONTRACT_ADDRESS=0x...

# ── On-chain wallet (server-side only) ───────────────────────
# Private key for submitting analyses on-chain
# Use a dedicated hot wallet — never your main wallet
RITUAL_PRIVATE_KEY=0x...

# ── App config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
